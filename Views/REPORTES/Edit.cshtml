@model Gestion_Tickets_Sp_Tec.Models.REPORTES

@{
    ViewBag.Title = "Asignación de Técnico - Ticket #" + Model.ID_REPORTE;
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-9">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-info text-white py-3">
                    <h4 class="mb-0 text-center"><i class="bi bi-person-gear me-2"></i> Gestión y Asignación de Ticket</h4>
                </div>
                <div class="card-body p-4">

                    @using (Html.BeginForm())
                    {
                        @Html.AntiForgeryToken()
                        @Html.HiddenFor(model => model.ID_REPORTE)

                        <div class="form-horizontal">
                            @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

                            <div class="row mb-4">
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Usuario que Reporta</label>
                                    @Html.DropDownList("ID_USUARIO", null, htmlAttributes: new { @class = "form-control bg-light", @disabled = "disabled" })
                                    @Html.HiddenFor(model => model.ID_USUARIO) @* Se envía oculto porque el select está disabled *@
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Prioridad Actual</label>
                                    @Html.EditorFor(model => model.PRIORIDAD, new { htmlAttributes = new { @class = "form-control bg-light", @readonly = "readonly" } })
                                </div>
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-bold">Descripción del Problema</label>
                                @Html.TextAreaFor(model => model.DESCRIPCION, new { @class = "form-control bg-light", @rows = "2", @readonly = "readonly" })
                            </div>

                            <hr />

                            <div class="row bg-light p-3 rounded shadow-sm border-start border-4 border-info">
                                <div class="col-md-12 mb-3">
                                    <label class="form-label fw-bold text-info"><i class="bi bi-person-check"></i> Personal Técnico Asignado</label>
                                    @* LÍNEA SOLICITADA *@
                                    @Html.DropDownList("ID_TECNICO", null, "-- Seleccionar Técnico --", htmlAttributes: new { @class = "form-select border-info shadow-sm" })

                                    @Html.ValidationMessageFor(model => model.ID_TECNICO, "", new { @class = "text-danger small" })
                                    <small class="text-muted">Solo se muestran usuarios con el Rol de Técnico en esta lista.</small>
                                </div>

                                <div class="col-md-6">
                                    @Html.LabelFor(model => model.ESTADO, new { @class = "form-label fw-bold" })
                                    @Html.DropDownListFor(model => model.ESTADO, new List<SelectListItem>
                                    {
                                        new SelectListItem{ Text="ACTIVO", Value="ACTIVO" },
                                        new SelectListItem{ Text="INACTIVO", Value="INACTIVO" },
                                        new SelectListItem{ Text="SOLUCIONADO", Value="SOLUCIONADO" }
                                    }, new { @class = "form-select" })
                                </div>

                                <div class="col-md-6">
                                    @Html.LabelFor(model => model.FECHA_SOLUCION, "Fecha de Solución", new { @class = "form-label fw-bold" })
                                    @Html.EditorFor(model => model.FECHA_SOLUCION, new { htmlAttributes = new { @class = "form-control", @type = "datetime-local" } })
                                </div>
                            </div>

                            <div class="mt-4">
                                @Html.LabelFor(model => model.OBSERVACIONES, "Observaciones Finales", new { @class = "form-label fw-bold" })
                                @Html.TextAreaFor(model => model.OBSERVACIONES, new { @class = "form-control", @rows = "3", @placeholder = "Detalle de la solución brindada..." })
                            </div>

                            <div class="d-flex justify-content-between align-items-center mt-5">
                                <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                                    <i class="bi bi-arrow-left"></i> Regresar
                                </a>
                                <button type="submit" class="btn btn-info px-5 fw-bold text-white shadow">
                                    <i class="bi bi-check-all"></i> Actualizar y Asignar
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}